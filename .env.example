LLM_PROVIDER=mock                # mock | anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Use memory:// to run with no database at all (keyless, zero-infra demo/dev).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mentor
CONTEXT_WINDOW_TURNS=8           # W: turns kept verbatim before summarizing
RESOURCE_CACHE_TTL_SECONDS=86400
PORT=8000
